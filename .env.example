# Copy to .env and adjust values.

# After first deploy, seed the Chynae v3.0 chart of accounts (required for journals & bookings):
#   npm run seed:chart-v3
# (same as npm run seed:accounting)

# Required — MongoDB (local or Atlas)
# Local:
# MONGO_URI=mongodb://127.0.0.1:27017/valleyroad
# Atlas (replace user, password, cluster host, db name as needed):
# MONGO_URI=mongodb+srv://USER:PASSWORD@cluster0.vja2fzx.mongodb.net/valleyroad?retryWrites=true&w=majority
MONGO_URI=mongodb://127.0.0.1:27017/valleyroad

# Required for JWT auth (use a long random string in production)
JWT_SECRET=change-me-to-a-long-random-string

# Optional
# PORT=5000
# JWT_EXPIRES_IN=7d
# FRONTEND_URL=http://localhost:5173
# Path segment for guest “track booking” page (link in emails): {FRONTEND_URL}/{path}?email=&trackingCode=
# FRONTEND_GUEST_TRACK_PATH=track
# BUSINESS_NAME=Valley Croft Accommodation
# Optional email branding
# MAIL_ACCENT_COLOR=#2f5d50
# MAIL_LOGO_URL=https://example.com/logo.png
# Deposit/cancellation wording in guest emails (optional; default: deposit on confirm, free cancel 48h after confirmation email, then 50% refund)
# MAIL_CANCELLATION_POLICY=Your full policy text here. Use one line or quoted multiline.

# --- Booking emails (optional) ---
# Comma-separated: notified when a guest submits a request OR when staff creates an internal booking.
# Guest gets “request received” on submit if mail is configured; admins only if this is set.
# BOOKING_ADMIN_EMAIL=owner@example.com,admin@example.com
# (alias) BOOKING_NOTIFY_EMAIL=
# Outbound mail is logged in MongoDB (Email collection); list via GET /api/emails (admin/ceo/finance).

# --- Invoice email (optional; if unset, email is skipped) ---
#
# Option A — any SMTP (e.g. provider relay)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# MAIL_FROM="Valley Croft Accommodation <bookings@example.com>"
#
# Option B — Gmail with App Password (easiest; Google Account must have 2-Step Verification on)
# Create: Google Account → Security → 2-Step Verification → App passwords → Mail / Other.
# Use the 16-character app password here — NOT your normal Google sign-in password.
# GMAIL_USER=you@gmail.com
# GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
# (alias) GMAIL_PASSWORD= or GOOGLE_APP_PASSWORD= — same as GMAIL_APP_PASSWORD; prefer GMAIL_APP_PASSWORD
# MAIL_FROM="Valley Croft Accommodation <you@gmail.com>"
#
# Option C — Gmail with OAuth2 (Google Cloud client id + secret + refresh token)
# Enable Gmail API; scope https://mail.google.com/ (or gmail.send). Tokens: developers.google.com/oauthplayground
# If GMAIL_APP_PASSWORD is set, the server uses Option B first (OAuth vars are ignored for SMTP).
# GMAIL_USER=you@gmail.com
# GMAIL_CLIENT_ID=....apps.googleusercontent.com
# GMAIL_CLIENT_SECRET=
# GMAIL_REFRESH_TOKEN=
# MAIL_FROM="Valley Croft Accommodation <you@gmail.com>"

# --- Invoice WhatsApp via Meta Cloud API (optional) ---
# WHATSAPP_ACCESS_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID=
# WHATSAPP_API_VERSION=v21.0
# For production, create a template in Meta Business Suite and set its name + language.
# Template body should have 4 variables: guest name, invoice number, total, short note.
# WHATSAPP_TEMPLATE_NAME=invoice_ready
# WHATSAPP_TEMPLATE_LANG=en_US
# If WHATSAPP_TEMPLATE_NAME is unset, the API sends a plain text message (may only work
# inside the customer service window or in sandbox).

# AWS_REGION=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_BUCKET=valleycroft
# AWS_REGION=eu-north-1
# (Region must be the full code, e.g. eu-north-1 — not eu-north1.)

# Optional — npm run seed:rooms: keys s3://<bucket>/<prefix>/<filename> → https://<bucket>.s3.<region>.amazonaws.com/<prefix>/...
# Default prefix matches getUploadKey() in src/middleware/upload.js (uploads/)
# S3_ROOM_IMAGE_PREFIX=uploads
# S3_PUBLIC_URL_BASE=https://your-cdn.example.com   (http:// upgraded to https except localhost)
#
# If S3 is not set, seed:rooms can still store absolute HTTPS image URLs using your marketing site origin:
# ROOM_IMAGE_SITE_BASE=https://www.valleycroft.example
# (or FRONTEND_URL — first origin if comma-separated; http:// becomes https:// except localhost)
